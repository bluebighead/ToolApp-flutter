<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- 申请网络权限，用于网速测试（HTTP HEAD） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 申请麦克风权限，用于分贝测试 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- 视频格式转换：读取设备上的 M3U8 源文件 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- 视频格式转换：Android 13+ 细粒度读取媒体文件 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- v1.55.0+ 音乐播放器：Android 13+ 读取音频文件 -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- v1.55.0+ 音乐播放器：扫描设备全部存储目录 -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <!-- 视频格式转换：保存转换后的 MP4 文件到下载目录（可选） -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:replace="android:maxSdkVersion" />
    <!-- 摄像头检测：设备检修工具中的摄像头测试 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <!-- 视频转换后台进度：Android 13+ 通知权限（弹转换进度通知用） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 视频转换后台运行：避免系统杀进程 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 联机掷骰子：WiFi 多播锁（UDP 广播需要） -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <!-- 联机掷骰子：检查网络连接状态 -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- NFC WiFi速写：需要开关WiFi状态、连接网络的权限 -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!-- NFC WiFi碰卡自动连接：requestNetwork需要此权限 -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <!-- Android 12+：WiFi扫描需要 NEARBY_WIFI_DEVICES 权限（替代原位置权限） -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" />
    <!-- 心率广播接收器：BLE 蓝牙低功耗权限 -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- BLE 广播权限：Android 12+ 作为 Peripheral 发布广播需要 -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- v1.52.5+ GPS定位检测：粗略定位权限（GPS检测需要） -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- v1.54.0+ Android Profiler：查看进程排行和耗电排行 -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- v1.53.0+ NFC读写器：NFC通信权限 -->
    <uses-permission android:name="android.permission.NFC" />
    <!-- v1.60.1+ 电池健康度检测：读取 dumpsys battery 数据 -->
    <uses-permission android:name="android.permission.DUMP"
        tools:ignore="ProtectedPermissions" />
    <uses-feature android:name="android.hardware.nfc" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />
    <application
        android:label="toolapp"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- NFC投屏速写：碰卡后通过deep link自动启动投屏 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="toolapp" android:host="screencast"/>
            </intent-filter>
            <!-- NFC回家模式：碰卡后通过deep link执行组合指令 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="toolapp" android:host="home"/>
            </intent-filter>
            <!-- NFC WiFi速写：碰卡后自动连接WiFi -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="application/vnd.wfa.wsc"/>
            </intent-filter>
            <!-- NFC链接速写：碰卡后打开指定URL -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="http"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="https"/>
            </intent-filter>
            <!-- NFC文本速写：碰卡后显示文本 -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
            <!-- NFC名片速写：碰卡后显示vCard -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/vcard"/>
            </intent-filter>
            <!-- NFC导航速写：碰卡后打开地图 -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="geo"/>
            </intent-filter>
            <!-- NFC支付/社交速写：碰卡后打开支付宝/微信/QQ
                 本应用拦截这些scheme的NFC消息，然后在onNewIntent中
                 通过ACTION_VIEW转发给对应的第三方应用 -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="alipays"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="weixin"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="mqqwpa"/>
            </intent-filter>
            <!-- NFC自定义MIME类型：本应用专用NFC数据格式
                 用于微信/QQ/支付宝等第三方应用的NFC跳转
                 AAR+自定义MIME确保本应用100%能接收到NFC intent -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="application/vnd.com.example.toolapp.nfc"/>
            </intent-filter>
            <!-- NFC通用TECH/TAG发现：兜底intent filter，确保任何NFC标签都能被本应用捕获 -->
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
            <meta-data android:name="android.nfc.action.TECH_DISCOVERED"
                       android:resource="@xml/nfc_tech_filter"/>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!--
          自定义 FileProvider：
            - 用于"视频转换完成"页面的"打开文件"/"打开目录"功能
            - 把 App 私有目录（getApplicationDocumentsDirectory 对应 app_flutter/）下的视频
              以 content:// URI 暴露给系统播放器/文件管理器，规避 Android 7.0+ 的
              FileUriExposedException
            - authorities 用 ${applicationId} 占位，避免和其他 App 冲突
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        <!--
          视频转换前台服务：
            - 在 FFmpeg 转换期间保持 App 进程不被系统限制（Doze / App Standby）
            - 息屏、切后台、离开页面时 FFmpeg 仍能正常执行
            - 通知栏持续显示转换进度，用户可随时查看
        -->
        <service
            android:name=".ConvertForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <!--
          WebSocket连接保活前台服务：
            - App切后台时保持WebSocket连接不被系统杀掉
            - 使用WakeLock防止CPU休眠导致心跳中断
            - 通知栏显示"设备连接中"状态
        -->
        <service
            android:name=".WebSocketForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- 支持 url_launcher：打开 https 官网链接 -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <category android:name="android.intent.category.BROWSABLE"/>
            <data android:scheme="https"/>
        </intent>
        <!-- 支持 url_launcher：打开 http 链接 -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <category android:name="android.intent.category.BROWSABLE"/>
            <data android:scheme="http"/>
        </intent>
        <!-- NFC跳转：声明微信/QQ/支付宝包名，Android 11+必须声明才能通过setPackage启动 -->
        <package android:name="com.tencent.mm"/>
        <package android:name="com.tencent.mobileqq"/>
        <package android:name="com.eg.android.AlipayGphone"/>
    </queries>
</manifest>
